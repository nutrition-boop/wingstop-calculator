ng]:font-bold [&_a]:text-[#006938] [&_a]:font-bold [&_a:hover]:underline","dangerouslySetInnerHTML":{"__html":"Our 24-piece and 30-piece packs are the most popular choices for families. For larger parties, the 50-piece and 100-piece packs offer the best value. Every group pack comes with large sides like fries and veggie sticks, plus plenty of dipping sauces. If anyone in your group has allergies, please review the <a href=\"/allergen-menu\" class=\"text-[#006938] font-bold hover:underline\">allergen menu</a> before you order."}}]]}],["$","div",null,{"children":[["$","div",null,{"className":"flex items-center gap-4 mb-6","children":[["$","div",null,{"className":"w-1.5 h-8 bg-[#006938] rounded-full"}],["$","h2",null,{"className":"text-2xl md:text-3xl font-black italic uppercase tracking-tight text-gray-900 leading-none","children":"Detailed Nutrition & Calorie Facts"}]]}],["$","div",null,{"className":"w-16 h-1 bg-[#FDB913] rounded-full ml-6 opacity-60 mb-6"}],["$","div",null,{"className":"text-gray-600 leading-relaxed text-base ml-6 [&_strong]:text-gray-900 [&_strong]:font-bold [&_a]:text-[#006938] [&_a]:font-bold [&_a:hover]:underline","dangerouslySetInnerHTML":{"__html":"We provide full nutrition facts for all our group packs so you can plan your meal. You can see the total calories, protein, and fat for each pack here. This helps you track your share of the meal and balance your daily diet. Use our <a href=\"/\" class=\"text-[#006938] font-bold hover:underline\">Wingstop nutrition calculator</a> to see the numbers for your portion."}}]]}]]}]}],["$","section",null,{"className":"py-24 bg-gray-50 border-t border-gray-100","children":["$","div",null,{"className":"max-w-[900px] mx-auto px-6","children":[["$","div",null,{"className":"flex items-center gap-4 mb-10","children":[["$","div",null,{"className":"w-1.5 h-8 bg-[#006938] rounded-full"}],["$","h2",null,{"className":"text-2xl md:text-3xl font-black italic uppercase tracking-tight text-gray-900 leading-none","childr